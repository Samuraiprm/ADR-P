{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Ingestion",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Events RPS",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(adr_received_events_total[5m])",
          "legendFormat": "Received",
          "refId": "A"
        },
        {
          "expr": "rate(adr_validated_events_total[5m])",
          "legendFormat": "Validated",
          "refId": "B"
        },
        {
          "expr": "rate(adr_dropped_events_total[5m])",
          "legendFormat": "Dropped",
          "refId": "C"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 }
    },
    {
      "title": "HTTP Requests",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(adr_http_requests_total[5m])",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 }
    },
    {
      "title": "HTTP Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(adr_http_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(adr_http_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 }
    },
    {
      "title": "Detection",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "title": "Verdict Distribution",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "adr_events_processed_total{verdict=\"BLOCK\"}",
          "legendFormat": "BLOCK",
          "refId": "A"
        },
        {
          "expr": "adr_events_processed_total{verdict=\"WARN\"}",
          "legendFormat": "WARN",
          "refId": "B"
        },
        {
          "expr": "adr_events_processed_total{verdict=\"PASS\"}",
          "legendFormat": "PASS",
          "refId": "C"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 }
    },
    {
      "title": "Rule Efficiency",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (rule_name) (adr_rule_triggers_total)",
          "legendFormat": "{{rule_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 }
    },
    {
      "title": "ML Anomaly Score",
      "type": "heatmap",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "adr_anomaly_score_bucket",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 }
    },
    {
      "title": "Processing",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "title": "Events Consumed vs Failed",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(adr_events_consumed_total[5m])",
          "legendFormat": "Consumed",
          "refId": "A"
        },
        {
          "expr": "rate(adr_events_failed_total[5m])",
          "legendFormat": "Failed",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 }
    },
    {
      "title": "Service Health",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "adr_redis_connected",
          "legendFormat": "Redis",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "adr_db_connected",
          "legendFormat": "PostgreSQL",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "adr_ml_model_trained",
          "legendFormat": "ML Model",
          "refId": "C",
          "instant": true
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["adr-p", "abuse-detection"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "ADR-P Dashboard",
  "uid": "adr-p-dashboard",
  "version": 1
}
